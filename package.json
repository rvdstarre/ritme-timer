{
  "name": "ritme-timer",
  "version": "0.4.0",
  "description": "Voedings- en drinkritme herinneringsapp",
  "main": "out/main/index.js",
  "type": "module",
  "author": {
    "name": "Robbert van der Starre",
    "email": "info@starrevisie.nl"
  },
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:web": "electron-vite build && node scripts/copy-web.js",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/local-notifications": "^7.0.0",
    "@capacitor/preferences": "^7.0.0",
    "electron-store": "^10.0.1",
    "electron-updater": "^6.3.9",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "nl.starrevisie.ritme-timer",
    "productName": "Ritme Timer",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "certificateFile": "build/codesign.pfx",
      "certificatePassword": ""
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.healthcare-fitness",
      "darkModeSupport": true
    },
    "dmg": {
      "title": "RitmeTimer-${version}",
      "sign": false
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm"],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "publish": {
      "provider": "github",
      "owner": "rvdstarre",
      "repo": "ritme-timer-releases"
    }
  }
}
