{
  "name": "ritme-timer",
  "version": "0.1.0",
  "description": "Voedings- en drinkritme herinneringsapp",
  "main": "dist-electron/main/index.js",
  "author": "Robbert van der Starre",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:web": "vite build --outDir dist-web",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/local-notifications": "^7.0.0",
    "@capacitor/preferences": "^7.0.0",
    "electron-store": "^10.0.1",
    "electron-updater": "^6.3.9",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "nl.starrevisie.ritme-timer",
    "productName": "Ritme Timer",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "rvdstarre",
      "repo": "ritme-timer-releases"
    }
  }
}
